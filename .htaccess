# Zacharias Polonius — zpolonius.dk
# VIGTIGT: Denne fil SKAL hedde præcis ".htaccess" på serveren.

# Forhindr mappe-visning (sikkerhed)
Options -Indexes

# Custom 404 side
ErrorDocument 404 /404.html

# Redirect www til non-www (valgfrit — kommenter ud hvis ikke ønsket)
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Sørg for HTTPS (valgfrit — kommenter ud hvis Simply håndterer det)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Blokér adgang til følsomme filer
<FilesMatch "(wp-config\.php|\.env|migrate\.php|generate-hash\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>
