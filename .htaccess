# Zacharias Polonius — zpolonius.dk
# VIGTIGT: Denne fil SKAL hedde præcis ".htaccess" på serveren.

# Forhindr mappe-visning (sikkerhed)
Options -Indexes

# Custom 404 side
ErrorDocument 404 /404.html

# --- SIKKERHEDS HEADERS (Google & Trust Anbefalinger) ---
<IfModule mod_headers.c>
    # Beskyt mod Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Beskyt mod MIME-sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Browser features (XSS beskyttelse og privatliv)
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"

    # Content Security Policy (CSP)
    # Tillader scripts fra eget domæne, Quill CDN, Cloudflare CDN (Vanilla Tilt), og Spotify
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.quilljs.com cdn.jsdelivr.net cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com cdn.quilljs.com cdn.jsdelivr.net; font-src 'self' fonts.gstatic.com; img-src 'self' data:; connect-src 'self' generativelanguage.googleapis.com cdn.jsdelivr.net; frame-src 'self' open.spotify.com;"

    # Force HTTPS (HSTS) - Gælder i 1 år
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Redirect www til non-www (valgfrit — kommenter ud hvis ikke ønsket)
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Sørg for HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Dynamisk Sitemap Rewrite (xml -> php)
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Blokér adgang til følsomme filer
<FilesMatch "(wp-config\.php|\.env|migrate\.php|generate-hash\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- CACHING (Browser Cache Optimization) ---
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Standard: 1 måned
    ExpiresDefault "access plus 1 month"
    
    # CSS & JS: 1 år (da de har versions-tags eller sjældent ændres)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Billeder: 1 år
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fonts: 1 år
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
